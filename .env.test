# .env.test - Test Environment Configuration
# Copy this to .env.test and update with test values

# Database
MONGODB_URI=mongodb://localhost:27017/vaultx-test

# Server
PORT=3001
DOMAIN=localhost:3001
SECURE_MODE=false
TRUST_PROXY=false
TIMEOUT=30000

# JWT & Session
SECRET_ACCESS_TOKEN=test-secret-key-12345678901234567890
SECRET_API_KEY=test-api-key-12345678901234567890

# Database Mode (for testing)
TESTDB=true
